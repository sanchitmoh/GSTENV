# === GST Agent Environment ===
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── API / Network ────────────────────────────────────────────────
# Base URL of the environment API (local or HuggingFace Space)
API_BASE_URL=http://localhost:7860
API_HOST=0.0.0.0
API_PORT=7860

# ── LLM / Model ─────────────────────────────────────────────────
# Primary model for accurate reasoning (Auditor, Reporter)
MODEL_NAME=gpt-4
# Fast model for classification tasks (Matcher, Validator)
FAST_MODEL_NAME=gpt-3.5-turbo

# OpenAI API key (or compatible endpoint)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Optional: Google Gemini API key (if using Gemini instead of OpenAI)
# GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxx

# ── Data Generation ──────────────────────────────────────────────
# Seed for deterministic data generation (default: 42)
DATA_SEED=42

# ── Session Management ───────────────────────────────────────────
# Session time-to-live in seconds (default: 1800 = 30 minutes)
SESSION_TTL_SECONDS=1800
# Cleanup interval for expired sessions (default: 60 seconds)
SESSION_CLEANUP_INTERVAL=60

# ── Timeouts ─────────────────────────────────────────────────────
# Timeout for /reset endpoint (default: 60 seconds)
RESET_TIMEOUT_SECONDS=60
# Timeout for /step endpoint (default: 30 seconds)
STEP_TIMEOUT_SECONDS=30
# Total inference timeout (default: 1140 = 19 minutes)
INFERENCE_TIMEOUT_SECONDS=1140

# ── Rate Limiting ────────────────────────────────────────────────
# Max requests per window (default: 100)
RATE_LIMIT_REQUESTS=100
# Window size in seconds (default: 60)
RATE_LIMIT_WINDOW=60

# ── Security ─────────────────────────────────────────────────────
# API key for authenticated endpoints
# If unset, an ephemeral key is auto-generated at startup (logged as warning)
GST_API_KEY=

# CORS allowed origins (comma-separated). Use '*' for open access.
# In production, set explicit origins: https://your-frontend.com
ALLOWED_ORIGINS=*

# Maximum request body size in bytes (default: 1MB = 1048576)
MAX_REQUEST_BODY_BYTES=1048576

# ── Leaderboard ──────────────────────────────────────────────────
# Max entries stored in leaderboard (default: 50)
LEADERBOARD_MAX_ENTRIES=50
# Optional: custom path for leaderboard SQLite database
# LEADERBOARD_DB_PATH=/app/data/leaderboard.db

# ── Curriculum ───────────────────────────────────────────────────
# Score thresholds for auto-advancing difficulty
CURRICULUM_EASY_THRESHOLD=0.8
CURRICULUM_MEDIUM_THRESHOLD=0.75
CURRICULUM_HARD_THRESHOLD=0.7

# ── Deployment ───────────────────────────────────────────────────
# HuggingFace token for Space deployment
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
